<?xml version="1.0" encoding="UTF-8" ?>


<xs:schema
        xmlns:xs="http://www.w3.org/2001/XMLSchema"
        elementFormDefault="qualified">

    <xs:include schemaLocation="MessageFieldTypes.xsd"/>

    <xs:element name="AskSignUpMessage" type="AskSignUpMessageType"/>

    <xs:complexType name="AskSignUpMessageType">
        <xs:sequence>
            <xs:element name="image" type="xs:string"/>
            <xs:element name="username" type="usernameType"/>
            <xs:element name="password" type="passwordType"/>
            <xs:element name="nationality" type="nationalityType">
            </xs:element>
            <xs:element name="age" type="ageType"/>
        </xs:sequence>
    </xs:complexType>



</xs:schema>
