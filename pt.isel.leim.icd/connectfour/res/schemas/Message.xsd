<?xml version="1.0" encoding="UTF-8" ?>

<xs:schema
        xmlns:xs="http://www.w3.org/2001/XMLSchema"
        elementFormDefault="qualified">

    <xs:include schemaLocation="PingMessage.xsd"/>
    <xs:include schemaLocation="PongMessage.xsd"/>

    <xs:include schemaLocation="DropTokenMessage.xsd"/>
    <xs:include schemaLocation="OnTokenDroppedMessage.xsd"/>
    <xs:include schemaLocation="OnTokenNotDroppedMessage.xsd"/>

    <xs:include schemaLocation="OnPlayTurnMessage.xsd"/>
    <xs:include schemaLocation="OnWaitTurnMessage.xsd"/>

    <xs:include schemaLocation="OnWinMessage.xsd"/>
    <xs:include schemaLocation="OnLossMessage.xsd"/>

    <xs:include schemaLocation="AskSignUpMessage.xsd"/>
    <xs:include schemaLocation="GiveSignUpAcceptedMessage.xsd"/>

    <xs:include schemaLocation="AskLoginMessage.xsd"/>
    <xs:include schemaLocation="GiveLoginResultMessage.xsd"/>

    <xs:include schemaLocation="AskUpdateProfileMessage.xsd"/>
    <xs:include schemaLocation="GiveUpdatedProfileMessage.xsd"/>

    <xs:include schemaLocation="AskGameStatsMessage.xsd"/>
    <xs:include schemaLocation="GiveGamesStatsMessage.xsd"/>

    <xs:include schemaLocation="AskQueueGameMessage.xsd"/>
    <xs:include schemaLocation="AskQueueGameCancelMessage.xsd"/>
    <xs:include schemaLocation="GiveOpponentFoundMessage.xsd"/>

    <xs:include schemaLocation="GameOverMessage.xsd"/>

    <xs:element name="Message" type="MessageTypes"/>

    <xs:complexType name="MessageTypes">
        <xs:choice>
            <xs:element ref="PongMessage"/>
            <xs:element ref="PingMessage"/>

            <xs:element ref="DropTokenMessage"/>
            <xs:element ref="OnTokenDroppedMessage"/>
            <xs:element ref="OnTokenNotDroppedMessage"/>

            <xs:element ref="OnPlayTurnMessage"/>
            <xs:element ref="OnWaitTurnMessage"/>

            <xs:element ref="OnWinMessage"/>
            <xs:element ref="OnLossMessage"/>

            <xs:element ref="AskSignUpMessage"/>
            <xs:element ref="GiveSignUpAcceptedMessage"/>

            <xs:element ref="AskLoginMessage"/>
            <xs:element ref="GiveLoginResultMessage"/>

            <xs:element ref="AskUpdateProfileMessage"/>
            <xs:element ref="GiveUpdatedProfileMessage"/>

            <xs:element ref="AskGamesStatsMessage"/>
            <xs:element ref="GiveGamesStatsMessage"/>

            <xs:element ref="AskQueueGameMessage"/>
            <xs:element ref="AskQueueGameCancelMessage"/>
            <xs:element ref="GiveOpponentFoundMessage"/>

            <xs:element ref="GameOverMessage"/>

<!--testes-->
            <xs:element ref="GameStat"/>
        </xs:choice>
    </xs:complexType>
</xs:schema>
