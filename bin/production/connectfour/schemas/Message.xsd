<?xml version="1.0" encoding="UTF-8" ?>

<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified">

    <xs:include schemaLocation="PongMessage.xsd"/>
    <xs:include schemaLocation="PingMessage.xsd"/>

    <xs:complexType name="commTypes">
        <xs:sequence>
            <xs:choice>
                <xs:element ref="PongMessage"/>
                <xs:element ref="PingMessage"/>
            </xs:choice>
        </xs:sequence>

    </xs:complexType>

    <xs:element name="Message" type="commTypes"/>

</xs:schema>
