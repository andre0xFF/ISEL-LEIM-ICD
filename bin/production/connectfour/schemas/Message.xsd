<?xml version="1.0" encoding="UTF-8" ?>

<xs:schema
        xmlns:xs="http://www.w3.org/2001/XMLSchema"
        elementFormDefault="qualified">

    <xs:include schemaLocation="PongMessage.xsd"/>
    <xs:include schemaLocation="PingMessage.xsd"/>
    <xs:include schemaLocation="LoginMessage.xsd"/>
    <xs:include schemaLocation="UpdateProfileMessage.xsd"/>
    <xs:include schemaLocation="UpdateGameHistoryMessage.xsd"/>

    <xs:element name="Message" type="MessageTypes"/>

    <xs:complexType name="MessageTypes">
        <xs:choice>
            <xs:element ref="PongMessage"/>
            <xs:element ref="PingMessage"/>
            <xs:element ref="LoginMessage"/>
            <xs:element ref="UpdateProfileMessage"/>
            <xs:element ref="UpdateGameHistoryMessage"/>
        </xs:choice>
    </xs:complexType>

</xs:schema>
